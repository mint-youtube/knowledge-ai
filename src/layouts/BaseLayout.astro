---
import "../styles/global.css";
import { CHANNEL } from "../data/channel";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
}

const { title, description = CHANNEL.tagline, ogImage, pubDate } = Astro.props;
const fullTitle = title ? `${title} | ${CHANNEL.name}` : CHANNEL.name;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="canonical" href={canonicalURL} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content={pubDate ? "article" : "website"} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title={CHANNEL.name} href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=IBM+Plex+Sans+KR:wght@400;500;700&display=swap">
  
</head>
<body>
  <header class="site-header">
    <div style="max-width: var(--max-width-wide); margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <a href="/" class="brand">{CHANNEL.name}</a>
      <nav class="nav"><a href="/">home</a><a href="/tags/">tags</a><a href="/about/">about</a></nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div style="max-width: var(--max-width-wide); margin: 0 auto; font-family: var(--font-mono); font-size: 0.8rem;">
      // © {new Date().getFullYear()} {CHANNEL.name} · <a href="/rss.xml">rss</a> · <a href="/sitemap-index.xml">sitemap</a>
    </div>
  </footer>
</body>
</html>
